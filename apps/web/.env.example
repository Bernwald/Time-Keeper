NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app

# Instance mode: "shared" (default, multi-tenant) or "dedicated" (single tenant)
# INSTANCE_MODE=shared

# Dedicated instance only: fixed organization UUID (bypasses session-based org resolution)
# FIXED_ORG_ID=

# Optional: activates OpenAI embeddings (vector search)
OPENAI_API_KEY=

# Optional: activates LLM chat via Claude
ANTHROPIC_API_KEY=
